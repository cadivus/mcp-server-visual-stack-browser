{
  "name": "@cadivus/mcp-server-visual-stack-browser",
  "version": "0.1.1",
  "description": "MCP server for visual browser navigation, OCR-based coordinate clicking, and JS stack trace debugging.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-visual-stack-browser": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cadivus/mcp-server-visual-stack-browser.git"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "playwright": "^1.52.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3"
  }
}
